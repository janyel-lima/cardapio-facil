rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════
//   CARDÁPIO DIGITAL PRO — firestore.rules
//
//   Roles via Custom Claims (request.auth.token.role)
//   Migrado de: Firestore /users/{uid}.role  (get() por avaliação = custo extra)
//   Agora:      JWT claim in-process         (grátis, zero leitura Firestore)
// ═══════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuthed() {
      return request.auth != null;
    }

    // Lê a role direto do Custom Claim no JWT — sem get(), sem custo.
    // Definido por: Admin SDK (prod) ou seed-emulator.js (dev).
    function role() {
      return isAuthed() ? request.auth.token.get('role', '') : '';
    }

    // FIX: substituído `role() in ['admin', 'worker']` por `||` explícito.
    // O operador `in` com lista literal tem comportamento instável em algumas
    // versões do avaliador de regras (emulador e produção) — a forma canônica
    // é usar comparações explícitas, que são avaliadas de forma determinística.
    function isAdmin()  { return role() == 'admin'; }
    function isWorker() { return role() == 'admin' || role() == 'worker'; }


    // ── Config público ────────────────────────────────────────────────────────
    match /config/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── AdminConfig (protegida — senha admin, chave PIX, dados sensíveis) ─────
    // Leitura restrita a admin autenticado; nunca exposta ao cliente final.
    match /adminConfig/{doc} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }


    // ── Meta (orderCounter) ───────────────────────────────────────────────────
    match /meta/{doc} {
      allow read:  if true;
      allow write: if isWorker();
    }

    // ── Categorias ────────────────────────────────────────────────────────────
    match /categories/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Produtos ──────────────────────────────────────────────────────────────
    match /items/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Promoções ─────────────────────────────────────────────────────────────
    match /promotions/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Pedidos ───────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow create: if true;
      allow read:   if isWorker();
      allow update: if isWorker();
      allow delete: if isAdmin();
    }

    // ── Audit Log ─────────────────────────────────────────────────────────────
    match /auditLog/{id} {
      allow read:   if isAdmin();
      allow create: if isWorker();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ── Error Logs ────────────────────────────────────────────────────────────
    match /errorLogs/{id} {
      allow read:   if isWorker();
      allow create: if true;
      allow update: if isWorker();
      allow delete: if isAdmin();
    }


    // ── Users ─────────────────────────────────────────────────────────────────
    // Roles agora vivem nos Custom Claims do JWT — esta coleção é opcional.
    // Mantida para dados de perfil do usuário (displayName, phone, etc.)
    // que não devem ir para o token.
    match /users/{userId} {
      allow read:   if isAuthed() && request.auth.uid == userId;
      allow write:  if isAuthed() && request.auth.uid == userId;
    }
  }
}
